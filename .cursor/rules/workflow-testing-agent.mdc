  // 3. Получение документации по splitInBatches
  const nodeDocs = await mcp_n8n-mcp_n8n_get_node({
    nodeType: 'n8n-nodes-base.splitInBatches',
    detail: 'full',
    mode: 'docs'
  });
  
  // 4. Исправить splitInBatches connections
  const fixed = await fixSplitInBatchesConnections(workflowId, workflow);
  
  // 5. Проверить и исправить валидацию
  const validation = await mcp_n8n-mcp_n8n_validate_workflow({
    id: workflowId
  });
  
  if (validation.errors && validation.errors.length > 0) {
    const validationOps = [];
    for (const validationError of validation.errors) {
      if (validationError.message.includes('Expression format error')) {
        // Исправить через autofix
        await mcp_n8n-mcp_n8n_autofix_workflow({
          id: workflowId,
          applyFixes: true,
          fixTypes: ['expression-format']
        });
      }
    }
  }
  
  return fixed;
}

// НОВАЯ функция: Исправление unknown ошибок с поиском решения
async function fixUnknownError(workflowId, workflow, error) {
  // 1. Поиск решения через Context7
  try {
    const context7Libs = await mcp_context7_resolve-library-id({
      libraryName: 'n8n'
    });
    // Можно использовать найденную библиотеку для поиска документации
  } catch (e) {
    // Context7 недоступен - продолжаем без него
  }
  
  // 2. Поиск решения через web_search
  const webResults = await web_search({
    search_term: `n8n ${error.message} ${error.node}`
  });
  
  // 3. Получение документации по узлу
  const node = workflow.nodes.find(n => n.name === error.node || n.id === error.node);
  if (node) {
    const nodeDocs = await mcp_n8n-mcp_n8n_get_node({
      nodeType: node.type,
      detail: 'full',
      mode: 'docs'
    });
  }
  
  // 4. Анализ найденных решений и применение исправления
  // (логика зависит от конкретной ошибки)
  
  return false; // Если не удалось найти решение
}

// НОВОЕ: Функция проверки результатов в БД
async function checkDatabaseResults(workflowId, workflow, executionDetails) {
  /**
   * Проверяет наличие данных в БД после успешного execution
   * 
   * Алгоритм:
   * 1. Найти все Supabase nodes с операцией 'create' в workflow
   * 2. Извлечь имена таблиц из tableId (выражение ={{ "table_name" }})
   * 3. Проверить наличие записей в БД через Supabase MCP
   * 4. Для event_log - проверить по event_type из имени узла
   * 
   * Возвращает:
   * - success: true если найдена хотя бы одна запись в целевых таблицах
   * - results: массив результатов проверки для каждой таблицы
   * - reason: причина успеха/неудачи
   */
  
  // 1. Определить, какие таблицы должны быть проверены
  // Анализируем Supabase nodes в workflow для определения целевых таблиц
  const supabaseNodes = workflow.nodes.filter(node => 
    node.type === 'n8n-nodes-base.supabase' && 
    (node.parameters?.operation === 'create' || node.parameters?.operation === 'update') &&
    node.parameters?.useCustomSchema === true &&
    node.parameters?.schema === 'genomai'
  );
  
  if (supabaseNodes.length === 0) {
    // Если нет create операций - проверяем только execution status
    return { success: true, results: [], reason: "no_create_operations" };
  }
  
  // 2. Для каждой create операции проверяем наличие записи в БД
  const results = [];
  const checks = [];
  
  for (const node of supabaseNodes) {
    const tableName = extractTableNameFromExpression(node.parameters.tableId);
    if (!tableName) continue;
    
    // Определяем, какие поля использовать для проверки
    // Обычно это entity_id из event_log или id из созданной записи
    const checkQuery = {
      table: tableName,
      schema: 'genomai',
      // Проверяем последние записи (созданные в последние 5 минут)
      filters: {
        conditions: [
          {
            keyName: 'created_at',
            condition: 'gte',
            keyValue: new Date(Date.now() - 5 * 60 * 1000).toISOString()
          }
        ]
      },
      limit: 10
    };
    
    checks.push({
      node: node.name,
      table: tableName,
      query: checkQuery
    });
  }
  
  // 3. Выполнить проверки через Supabase MCP
  for (const check of checks) {
    try {
      // Используем Supabase MCP для проверки записей
      const records = await mcp_supabase-buying_execute_sql({
        query: `
          SELECT * FROM genomai.${check.table}
          WHERE created_at >= NOW() - INTERVAL '5 minutes'
          ORDER BY created_at DESC
          LIMIT 10;
        `
      });
      
      if (records && records.length > 0) {
        results.push({
          table: check.table,
          node: check.node,
          recordsFound: records.length,
          latestRecord: records[0],
          success: true
        });
      } else {
        // Если это event_log - проверяем по event_type
        if (check.table === 'event_log') {
          // Проверяем последние события по типу
          const eventType = extractEventTypeFromNode(check.node);
          if (eventType) {
            const events = await mcp_supabase-buying_execute_sql({
              query: `
                SELECT * FROM genomai.event_log
                WHERE event_type = '${eventType}'
                  AND occurred_at >= NOW() - INTERVAL '5 minutes'
                ORDER BY occurred_at DESC
                LIMIT 10;
              `
            });
            
            if (events && events.length > 0) {
              results.push({
                table: check.table,
                node: check.node,
                eventType: eventType,
                recordsFound: events.length,
                latestRecord: events[0],
                success: true
              });
            }
          }
        }
      }
    } catch (error) {
      log('error', `Ошибка при проверке таблицы ${check.table}: ${error.message}`);
    }
  }
  
  // 4. Определить успешность проверки
  // Успешно, если найдена хотя бы одна запись в целевых таблицах
  const success = results.length > 0 && results.some(r => r.success);
  
  return {
    success: success,
    results: results,
    reason: success ? "records_found" : "no_records_found",
    checksPerformed: checks.length
  };
}

// Вспомогательные функции
function extractTableNameFromExpression(tableIdExpression) {
  // Извлекаем имя таблицы из выражения ={{ "table_name" }}
  if (typeof tableIdExpression === 'string') {
    const match = tableIdExpression.match(/=\{\{\s*"([^"]+)"\s*\}\}/);
    return match ? match[1] : null;
  }
  return null;
}

function extractEventTypeFromNode(nodeName) {
  // Извлекаем тип события из имени узла (например, "Emit RawMetricsObserved" -> "RawMetricsObserved")
  const eventMatch = nodeName.match(/Emit\s+(\w+)/i);
  return eventMatch ? eventMatch[1] : null;
}
