### Шаг 2: Анализ частоты ошибок

**Периодически анализировать логи:**

```javascript
// Функция анализа частоты ошибок
function analyzeErrorFrequency() {
  const logs = loadErrorLogs();
  
  // Группировка по типу ошибки
  const errorGroups = groupBy(logs, 'error.type');
  
  // Подсчет частоты
  const frequency = {};
  for (const [errorType, errors] of Object.entries(errorGroups)) {
    frequency[errorType] = {
      count: errors.length,
      lastOccurred: max(errors.map(e => e.timestamp)),
      successRate: calculateSuccessRate(errors)
    };
  }
  
  // Сортировка по частоте
  return Object.entries(frequency)
    .sort((a, b) => b[1].count - a[1].count)
    .filter(([type, stats]) => stats.count >= 3); // Минимум 3 повторения
}
```

### Шаг 3: Создание правил исправления

**Для частых ошибок (≥3 повторений):**

1. **Найти все успешные исправления:**
   ```javascript
   function extractFixPattern(errorType) {
     const successfulFixes = loadSuccessfulFixes(errorType);
     
     // Найти общий паттерн исправления
     const commonFix = findCommonPattern(successfulFixes);
     
     return {
       errorType: errorType,
       pattern: commonFix.pattern,
       operations: commonFix.operations,
       confidence: commonFix.confidence, // 0-1
       frequency: successfulFixes.length,
       lastUpdated: new Date().toISOString()
     };
   }
   ```

2. **Сохранить правило:**
   ```javascript
   // Файл: tests/logs/learned_fixes.json
   {
     "rules": [
       {
         "id": "rule-001",
         "errorType": "schema_validation",
         "errorPattern": {
           "nodeType": "n8n-nodes-base.supabase",
           "messageContains": ["schema", "validation"],
           "missingParameters": ["useCustomSchema", "schema"]
         },
         "fix": {
           "operations": [
             {
               "type": "updateNode",
               "condition": {
                 "nodeType": "n8n-nodes-base.supabase",
                 "missing": ["useCustomSchema"]
               },
               "updates": {
                 "parameters": {
                   "useCustomSchema": true,
                   "schema": "genomai"
                 }
               }
             }
           ]
         },
         "confidence": 0.95,
         "frequency": 15,
         "successRate": 0.98,
         "lastApplied": "2025-12-21T10:30:00Z",
         "createdAt": "2025-12-20T08:00:00Z"
       }
     ]
   }
   ```

### Шаг 4: Автоматическое применение правил

**При обнаружении ошибки:**

1. **Проверить, есть ли правило для этой ошибки:**
   ```javascript
   function findMatchingRule(error) {
     const rules = loadLearnedFixes();
     
     for (const rule of rules) {
       if (matchesErrorPattern(error, rule.errorPattern)) {
         // Проверить уверенность
         if (rule.confidence >= 0.8) {
           return rule;
         }
       }
     }
     
     return null;
   }
   ```

2. **Применить правило автоматически:**
   ```javascript
   async function applyLearnedFix(workflowId, error, rule) {
     log('info', `Применение изученного правила: ${rule.id} (confidence: ${rule.confidence})`);
     
     const workflow = await mcp_n8n-mcp_n8n_get_workflow({
       id: workflowId,
       mode: "full"
     });
     
     const operations = [];
     
     for (const fixOp of rule.fix.operations) {
       // Найти узлы, соответствующие условию
       const matchingNodes = workflow.nodes.filter(node => 
         matchesCondition(node, fixOp.condition)
       );
       
       for (const node of matchingNodes) {
         operations.push({
           type: "updateNode",
           nodeId: node.id,
           updates: fixOp.updates
         });
       }
     }
     
     if (operations.length > 0) {
       await mcp_n8n-mcp_n8n_update_partial_workflow({
         id: workflowId,
         operations: operations
       });
       
       // Записать применение правила
       logRuleApplication(rule.id, workflowId, true);
       
       return true;
     }
     
     return false;
   }
   ```

3. **Обновить статистику правила:**
   ```javascript
   function updateRuleStats(ruleId, success) {
     const rules = loadLearnedFixes();
     const rule = rules.find(r => r.id === ruleId);
     
     if (rule) {
       rule.lastApplied = new Date().toISOString();
       rule.frequency += 1;
       
       // Обновить success rate
       const recentApplications = getRecentApplications(ruleId, 10);
       rule.successRate = calculateSuccessRate(recentApplications);
       
       // Обновить confidence на основе success rate
       if (rule.successRate > 0.9) {
         rule.confidence = Math.min(1.0, rule.confidence + 0.01);
       } else if (rule.successRate < 0.7) {
         rule.confidence = Math.max(0.5, rule.confidence - 0.05);
       }
       
       saveLearnedFixes(rules);
     }
   }
   ```

