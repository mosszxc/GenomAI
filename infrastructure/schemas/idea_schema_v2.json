{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Idea Schema v2",
  "description": "Canonical Schema v2 - Extended with copywriting psychology fields based on expert analysis (Jake, John Benson)",
  "type": "object",
  "required": [
    "angle_type",
    "core_belief",
    "promise_type",
    "emotion_primary",
    "emotion_intensity",
    "message_structure",
    "opening_type",
    "state_before",
    "state_after",
    "context_frame",
    "source_type",
    "risk_level",
    "horizon",
    "schema_version"
  ],
  "properties": {
    "idea_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the idea"
    },
    "active_cluster_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "Current cluster assignment (may change over time)"
    },
    "angle_type": {
      "type": "string",
      "enum": ["pain", "fear", "hope", "curiosity", "authority", "social_proof", "urgency", "identity"],
      "description": "Primary angle of the message"
    },
    "core_belief": {
      "type": "string",
      "enum": [
        "problem_is_serious",
        "problem_is_hidden",
        "solution_is_simple",
        "solution_is_safe",
        "solution_is_scientific",
        "solution_is_unknown",
        "others_have_this_problem",
        "doctors_are_wrong",
        "time_is_running_out"
      ],
      "description": "Core belief being communicated"
    },
    "promise_type": {
      "type": "string",
      "enum": ["instant", "gradual", "effortless", "hidden", "scientific", "guaranteed", "preventive"],
      "description": "Type of promise made"
    },
    "emotion_primary": {
      "type": "string",
      "enum": ["fear", "relief", "anger", "hope", "curiosity", "shame", "trust"],
      "description": "Primary emotion evoked"
    },
    "emotion_intensity": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "Intensity of the primary emotion"
    },
    "message_structure": {
      "type": "string",
      "enum": [
        "problem_solution",
        "story_reveal",
        "myth_debunk",
        "authority_proof",
        "question_answer",
        "before_after",
        "confession"
      ],
      "description": "Structure of the message"
    },
    "opening_type": {
      "type": "string",
      "enum": ["shock_statement", "direct_question", "personal_story", "authority_claim", "visual_pattern_break"],
      "description": "Type of opening"
    },
    "state_before": {
      "type": "string",
      "enum": ["unsafe", "uncertain", "powerless", "ignorant", "overwhelmed", "excluded", "dissatisfied"],
      "description": "State before the solution"
    },
    "state_after": {
      "type": "string",
      "enum": ["safe", "confident", "in_control", "informed", "calm", "included", "satisfied"],
      "description": "State after the solution"
    },
    "context_frame": {
      "type": "string",
      "enum": ["institutional", "anti_authority", "peer_based", "expert_led", "personal_confession", "ironic"],
      "description": "Contextual framing"
    },
    "source_type": {
      "type": "string",
      "enum": ["internal", "spy", "human_override", "epistemic_shock"],
      "description": "Source of the idea"
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "Risk level of the idea"
    },
    "horizon": {
      "type": "string",
      "enum": ["T1", "T2", "T3"],
      "description": "Time horizon"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "schema_version": {
      "type": "string",
      "enum": ["v1", "v2"],
      "description": "Schema version"
    },

    "ump_present": {
      "type": "boolean",
      "description": "Whether a Unique Mechanism of Problem is present - the hidden reason they've been failing"
    },
    "ump_type": {
      "type": "string",
      "enum": ["hidden_cause", "wrong_approach", "missing_ingredient", "inflammation", "absorption", "none"],
      "description": "Type of UMP: what hidden problem is revealed"
    },
    "ums_present": {
      "type": "boolean",
      "description": "Whether a Unique Mechanism of Solution is present - how the product addresses the hidden problem"
    },
    "ums_type": {
      "type": "string",
      "enum": ["secret_ingredient", "new_technology", "natural_approach", "scientific_method", "none"],
      "description": "Type of UMS: what makes the solution different"
    },

    "paradigm_shift_present": {
      "type": "boolean",
      "description": "Whether the ad creates a paradigm shift - changes the reader's beliefs"
    },
    "paradigm_shift_type": {
      "type": "string",
      "enum": ["blame_shift", "new_understanding", "revelation", "myth_bust", "none"],
      "description": "Type of paradigm shift: how beliefs are changed"
    },

    "specificity_level": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "Level of specific details used ($974 vs 'I tried everything')"
    },
    "specificity_markers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["money_amount", "time_period", "product_names", "person_names", "locations", "statistics"]
      },
      "description": "Types of specific details present in the copy"
    },

    "hook_mechanism": {
      "type": "string",
      "enum": ["pattern_interrupt", "counter_intuitive", "specific_number", "confession", "direct_question", "shock_statement"],
      "description": "Mechanism used to stop the scroll within 0.8 seconds"
    },
    "hook_stopping_power": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "Estimated scroll-stopping power of the hook"
    },

    "proof_type": {
      "type": "string",
      "enum": ["personal_story", "expert_quote", "research", "testimonial", "statistics", "demonstration"],
      "description": "Primary type of proof used"
    },
    "proof_source": {
      "type": "string",
      "enum": ["self", "expert", "doctor", "research_institution", "customer", "celebrity"],
      "description": "Source of the credibility/proof"
    },

    "story_type": {
      "type": "string",
      "enum": ["direct", "parallel", "discovery", "confession", "transformation"],
      "description": "Type of story structure used"
    },
    "story_bridge_present": {
      "type": "boolean",
      "description": "Whether a story bridge connects problem to solution"
    },

    "desire_level": {
      "type": "string",
      "enum": ["surface", "deep"],
      "description": "Whether addressing surface desire (want wrinkles gone) or deep desire (afraid husband will leave)"
    },
    "emotional_trigger": {
      "type": "string",
      "enum": ["fear_of_loss", "shame", "social_rejection", "health_anxiety", "relationship_fear", "aging_fear", "financial_fear"],
      "description": "Primary emotional trigger being activated"
    },

    "social_proof_pattern": {
      "type": "string",
      "enum": ["single", "cascading", "stacked"],
      "description": "Pattern of social proof presentation"
    },
    "proof_progression": {
      "type": "string",
      "enum": ["immediate", "short_term", "long_term", "multi_stage"],
      "description": "Timeline of results shown (day 1 -> week 1 -> month 3)"
    },

    "cta_style": {
      "type": "string",
      "enum": ["direct", "two_step", "soft", "embedded"],
      "description": "Style of call-to-action"
    },
    "risk_reversal_type": {
      "type": "string",
      "enum": ["money_back", "performance_guarantee", "keep_bonus", "none"],
      "description": "Type of risk reversal offered"
    },

    "focus_score": {
      "type": "string",
      "enum": ["focused", "scattered"],
      "description": "Whether copy follows Rule of One or is scattered"
    },
    "idea_count": {
      "type": "integer",
      "enum": [1, 2, 3],
      "description": "Number of distinct ideas in the copy (1 is best per Rule of One)"
    },
    "emotion_count": {
      "type": "integer",
      "enum": [1, 2, 3],
      "description": "Number of distinct emotions targeted (1 is best per Rule of One)"
    }
  },
  "additionalProperties": false
}
