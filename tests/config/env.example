# GenomAI — Environment Variables Template
# Версия: v1.0
# Назначение: Шаблон для .env файла
# 
# Инструкция: Скопируйте этот файл в .env и заполните значениями
# cp tests/config/env.example .env

# ============================================
# n8n Configuration
# ============================================

# Webhook URL для ingestion
WEBHOOK_URL=http://localhost:5678/webhook/ingest/creative

# n8n API URL (для автоматизации тестирования workflows)
N8N_API_URL=https://kazamaqwe.app.n8n.cloud/api/v1

# n8n API Key (обязательно для test_n8n_workflow.js/sh)
# Получить: Settings → API → Create API Key
N8N_API_KEY=

# Workflow ID для тестирования (опционально, можно передать как аргумент)
WORKFLOW_ID=

# Timeout для ожидания execution (в миллисекундах, по умолчанию: 120000 = 2 минуты)
TIMEOUT=120000

# Интервал проверки нового execution (в миллисекундах, по умолчанию: 1000 = 1 секунда)
POLL_INTERVAL=1000

# Ждать ручного запуска если webhook не найден (true/false, по умолчанию: true)
WAIT_FOR_MANUAL=true

# ============================================
# Supabase Configuration
# ============================================

# Supabase Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (для публичного доступа)
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (для системного доступа)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase Database Connection String (для прямого подключения)
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ============================================
# Keitaro Configuration
# ============================================

# Keitaro API URL
KEITARO_API_URL=https://your-keitaro-instance.com/admin_api/v1

# Keitaro API Key
KEITARO_API_KEY=your-keitaro-api-key-here

# ============================================
# Telegram Bot Configuration
# ============================================

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Telegram Chat ID (для тестирования)
TELEGRAM_CHAT_ID=your-chat-id-here

# ============================================
# LLM Configuration
# ============================================

# OpenAI API Key (если используется)
OPENAI_API_KEY=your-openai-api-key-here

# LLM Model (если используется)
LLM_MODEL=gpt-4

# ============================================
# Transcription Configuration
# ============================================

# Transcription Provider API Key (если используется)
TRANSCRIPTION_API_KEY=your-transcription-api-key-here

# Transcription Provider URL
TRANSCRIPTION_API_URL=https://api.transcription-provider.com

# ============================================
# Testing Configuration
# ============================================

# Verbose output для тестовых скриптов
VERBOSE=false

# Test mode (использовать тестовые данные)
TEST_MODE=true

# ============================================
# Development Configuration
# ============================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug mode
DEBUG=true

# Log level (debug, info, warn, error)
LOG_LEVEL=debug

